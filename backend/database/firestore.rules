rules_version = '2';

// STARTER TEMPLATE — reflects the app's current `users/{uid}` access pattern.
// Review and expand for any additional collections before deploying to production.
service cloud.firestore {
  match /databases/{database}/documents {

    // A signed-in user may read and write only their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
